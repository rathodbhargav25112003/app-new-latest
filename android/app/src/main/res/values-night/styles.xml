<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <!-- Dark mode version of your theme -->
        <item name="pspdf__mainToolbarStyle">@style/MainToolbarStyle.Dark</item>
        <item name="android:selectableItemBackground">@android:color/transparent</item>
        <item name="android:selectableItemBackgroundBorderless">@android:color/transparent</item>
    </style>

    <style name="MainToolbarStyle.Dark" parent="MainToolbarStyle">
        <item name="pspdf__textColor">@color/white</item>
        <item name="pspdf__toolbarTheme">@style/ThemeOverlay.AppCompat.Dark.ActionBar</item>
        <item name="pspdf__toolbarPopupTheme">@style/ThemeOverlay.AppCompat.Dark</item>
        <item name="android:background">@drawable/transparent_selector</item>
    </style>

    <style name="LaunchTheme" parent="AppTheme">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <style name="NormalTheme" parent="PSPDFKit.Theme.Default">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>